#!/bin/sh

# Branch Naming Convention Validation
# Pattern: type/short-description OR main/deploy
# Examples:
#   feat/add-ai-suggestions ✅
#   fix/cors-lambda-issue ✅
#   chore/update-deps ✅
#   deploy ✅
#   main ✅
#   my-random-branch ❌

branch=$(git rev-parse --abbrev-ref HEAD)

# Allow protected branches
if echo "$branch" | grep -qE "^(main|master|deploy|develop)$"; then
  exit 0
fi

# Branch naming pattern
pattern="^(feat|fix|docs|chore|refactor|style|test|perf|ci|build|revert)\/[a-z0-9][a-z0-9-]{1,}$"

if ! echo "$branch" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid branch name: $branch"
  echo ""
  echo "Expected: type/short-description"
  echo ""
  echo "Valid types: feat, fix, docs, chore, refactor, style, test, perf, ci, build, revert"
  echo ""
  echo "Examples:"
  echo "  feat/add-ai-suggestions"
  echo "  fix/cors-lambda-issue"
  echo "  chore/update-deps"
  echo "  refactor/simplify-auth-flow"
  echo ""
  exit 1
fi
